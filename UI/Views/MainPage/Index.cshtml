@{
	Layout = null;
}

<!DOCTYPE html>

<html>
<head>
	<meta name="viewport" content="width=device-width" />
	<title>Araç Kiralama Sistemi</title>
	<!--Bootstrap Links-->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-Zenh87qX5JnK2Jl0vWa8Ck2rdkQ2Bzep5IDxbcnCeuOxjzrPF/et3URy9Bv1WTRi" crossorigin="anonymous">
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-OERcA2EqjJCMA+/3y+gxIOqMEjwtxJY7qPCqsdltbNJuaOe923+mo//f6V8Qbsw3" crossorigin="anonymous"></script>
	<!--IndexSheet.css-->
	<link href="~/stylesheets/indexsheet.css" rel="stylesheet" />
</head>
<body>
	<!--Navbar-->
	<nav class="navbar navbar-expand-lg bg-body-tertiary">
		<div class="container-md  d-flex justify-content-center">
            <a class="navbar-brand"><b>Araç Kiralama Sistemi</b></a>
		</div>
	</nav>

    <div class="wrapper">
        <div class="card-switch">
            <label class="switch">
                <input type="checkbox" class="toggle">
                <span class="slider"></span>
                <span class="card-side"></span>
                <div class="flip-card__inner">
                    <div class="flip-card__front">
                        <div class="title">Giriş Yap</div>
                        <form class="flip-card__form" action="">
                            <input class="flip-card__input" name="email" placeholder="E-Mail" type="email">
                            <input class="flip-card__input" name="password" placeholder="Şifre" type="password">
                            <button class="flip-card__btn">Giriş Yap</button>
                        </form>
                    </div>
                    <div class="flip-card__back">
                        <div class="title">Kayıt Ol</div>
                        <form class="flip-card__form" action="">
                            <input class="flip-card__input" placeholder="İsim-Soyisim" type="name">
                            <input class="flip-card__input" name="email" placeholder="E-Mail" type="email">
                            <input class="flip-card__input" name="password" placeholder="Şifre" type="password">
                            <button class="flip-card__btn">Kayıt Ol</button>
                        </form>
                    </div>
                </div>
            </label>
        </div>
    </div>
</body>
</html>
